# ============================================================================
# LinkSpark — Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyalayın ve değerleri doldurun.
# .env.local ASLA commit edilmez (.gitignore'da). Secret'ları koda gömmeyin.
# ============================================================================

# --- Supabase (zorunlu — boşsa uygulama demo modunda çalışır) ---------------
# Supabase proje ayarları → API bölümünden alınır.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Sunucu tarafı yüksek yetkili anahtar (ASLA client'a sızdırmayın).
# Yalnızca redirect hot-path, analitik yazımı ve webhook'larda kullanılır.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Uygulama ---------------------------------------------------------------
# Kısa linklerin ve kanonik URL'lerin temel adresi.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Piksel access token / link şifresi gibi hassas alanların AES-GCM şifrelemesi
# için 32 byte'lık (base64) anahtar. Üretmek için: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=

# KVKK: ham IP yerine tuzlanmış hash saklamak için kullanılan tuz.
IP_HASH_SALT=

# --- Stripe (faturalandırma — opsiyonel) ------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2025-02-24.acacia
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- AI UTM sihirbazı (opsiyonel) -------------------------------------------
ANTHROPIC_API_KEY=

# --- Upstash Redis (redirect hot-path sayaç / rate limit — opsiyonel) -------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
